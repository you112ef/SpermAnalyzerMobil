<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/button_circle"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Analysis Results"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <Button
                android:id="@+id/share_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="📤"
                android:textSize="16sp"
                android:background="@drawable/button_circle"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/export_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="💾"
                android:textSize="16sp"
                android:background="@drawable/button_circle"/>

        </LinearLayout>

        <!-- Image -->
        <ImageView
            android:id="@+id/result_image"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:scaleType="centerCrop"
            android:padding="8dp"/>

        <!-- Basic Metrics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cell Count Summary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/total_cells_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Cells: 0"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/motile_cells_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Motile Cells: 0"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/progressive_cells_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progressive Cells: 0"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/motility_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Motility: 0%"
                android:textSize="16sp"
                android:textColor="@color/accent_primary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/progressive_motility_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progressive Motility: 0%"
                android:textSize="16sp"
                android:textColor="@color/accent_secondary"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Motility Chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Motility Distribution"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/motility_chart"
                android:layout_width="match_parent"
                android:layout_height="250dp" />

        </LinearLayout>

        <!-- CASA Metrics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CASA Velocity Parameters"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/vap_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VAP: 0 μm/s"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/vcl_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VCL: 0 μm/s"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/vsl_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VSL: 0 μm/s"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/alh_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ALH: 0 μm"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/bcf_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BCF: 0 Hz"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Velocity Chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Velocity Comparison"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/velocity_chart"
                android:layout_width="match_parent"
                android:layout_height="200dp" />

        </LinearLayout>

        <!-- Derived Parameters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Derived Parameters"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lin_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LIN: 0%"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/str_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="STR: 0%"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/wob_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WOB: 0%"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>